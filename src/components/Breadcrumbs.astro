---
const { items = [] } = Astro.props;
---

<nav class="container py-5 text-sm text-ink/70" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && <span aria-hidden="true">/</span>}
        {index === items.length - 1 ? <span class="font-semibold text-ink">{item.label}</span> : <a class="hover:text-timber" href={item.href}>{item.label}</a>}
      </li>
    ))}
  </ol>
</nav>
