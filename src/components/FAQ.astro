---
const { faqs = [] } = Astro.props;
---

<div class="divide-y divide-charcoal/10 border-y border-charcoal/10">
  {faqs.map(([question, answer]) => (
    <details class="group py-5 sm:py-6">
      <summary class="flex cursor-pointer list-none items-center justify-between gap-5 font-bold text-charcoal">
        {question}
        <span class="grid h-7 w-7 shrink-0 place-items-center rounded-full bg-cream text-lg text-timber transition group-open:rotate-45">+</span>
      </summary>
      <p class="mt-3 leading-7 text-ink/70">{answer}</p>
    </details>
  ))}
</div>
