---
import { gallery } from '../data/site';
const { limit = gallery.length } = Astro.props;
---

<div class="grid gap-5 md:grid-cols-2">
  {gallery.slice(0, limit).map((image, index) => (
    <figure class="group relative overflow-hidden rounded-[1.25rem] bg-charcoal">
      <img class="aspect-[4/3] w-full object-cover opacity-95 transition duration-300 group-hover:scale-[1.03]" src={image.src} alt={image.alt} width={image.width} height={image.height} loading={index === 0 ? 'eager' : 'lazy'} decoding="async" />
      <figcaption class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/85 to-transparent px-5 pb-5 pt-12 text-sm font-extrabold text-white">{image.caption}</figcaption>
    </figure>
  ))}
</div>
