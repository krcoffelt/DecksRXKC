---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import GallerySlideshow from '../components/GallerySlideshow.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import { business } from '../data/site';
import { services } from '../data/services';
import { areas } from '../data/areas';
import { faqSchema, breadcrumbSchema } from '../data/schema';

const faqs = [
  ['How much does a new deck cost in Kansas City?', 'Cost depends on deck size, material, stairs, railing, access, and existing conditions. DecksRXKC provides project-specific estimates after reviewing your space.'],
  ['Do you build composite and wood decks?', 'Yes. DecksRXKC builds composite decks, wood decks, replacement decks, railings, stairs, and related outdoor living upgrades.'],
  ['Can you replace an old deck?', 'Yes. Replacement can keep a similar footprint or improve the layout, depending on the condition of the existing deck and local requirements.'],
  ['How long does a deck build usually take?', 'Timeline depends on project size, material availability, weather, permits where required, and site access. Your estimate can include realistic timing expectations.'],
  ['Do I need a permit for a deck in Kansas City?', 'Permit rules vary by city and project scope. Homeowners should verify local requirements or discuss likely requirements with DecksRXKC during the estimate.'],
  ['What areas around Kansas City do you serve?', 'DecksRXKC serves Kansas City and surrounding areas including Overland Park, Olathe, Lenexa, Shawnee, Leawood, Lee’s Summit, Blue Springs, Liberty, Parkville, and nearby communities.']
];

const serviceNotes = [
  'New builds planned around layout, access, and materials.',
  'Low-maintenance boards with clean railing details.',
  'Natural warmth, classic finish, practical value.',
  'Focused fixes for boards, stairs, and railings.',
  'Upgrade an aging deck with a better layout.'
];

const processSteps = [
  ['Request estimate', 'Send the basics.'],
  ['Site visit', 'We look at access, layout, and existing conditions.'],
  ['Plan materials', 'Choose deck boards, railing, stairs, and scope.'],
  ['Build', 'Construction starts with the approved plan.'],
  ['Walkthrough', 'Review the finished deck together.']
];
---

<BaseLayout title="Deck Builder Kansas City | Custom Decks, Repair & Replacement | DecksRXKC" description="DecksRXKC is a Kansas City deck builder for custom decks, composite decking, wood decks, deck repair, deck replacement, railings, stairs, and outdoor living upgrades." schemas={[faqSchema(faqs), breadcrumbSchema([{ label: 'Home', href: '/' }])]}>
  <section class="relative min-h-[calc(100svh-var(--header-height))] overflow-hidden bg-charcoal text-white">
    <img class="absolute inset-0 h-full w-full object-cover opacity-55" src="/images/kansas-city-large-backyard-deck-build.jpg" alt="Large backyard deck built by DecksRXKC in the Kansas City area" width="1440" height="1080" decoding="async" />
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal via-charcoal/75 to-charcoal/15"></div>
    <div class="container relative flex min-h-[calc(100svh-var(--header-height))] items-center py-20">
      <div class="max-w-3xl">
        <p class="eyebrow eyebrow-on-dark">Kansas City Deck Contractor</p>
        <h1 class="mt-5 font-display text-5xl font-semibold leading-[1.02] sm:text-6xl lg:text-7xl">DecksRXKC</h1>
        <p class="mt-6 max-w-2xl text-xl leading-8 text-white/80">Custom decks, replacement, repair, railings, stairs, and outdoor living upgrades in Kansas City.</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="btn btn-primary" href="#estimate">Request a Free Deck Estimate</a>
          <a class="btn btn-secondary" href="/services/">View Our Deck Services</a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-5">
    <div class="container grid gap-3 text-sm font-extrabold text-charcoal sm:grid-cols-2 lg:grid-cols-4">
      {['Kansas City owned', 'Free estimates', 'Custom deck design', 'Quality craftsmanship'].map((item) => <div class="rounded-full bg-cream px-5 py-3 text-center">{item}</div>)}
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-stretch">
        <div class="overflow-hidden rounded-[1.25rem] bg-charcoal shadow-soft">
          <img
            class="h-full min-h-[420px] w-full object-cover opacity-90"
            src="/images/kansas-city-composite-deck-cable-railing-stairs.jpg"
            alt="Composite deck stairs and cable railing project by DecksRXKC"
            width="1600"
            height="1215"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="flex flex-col justify-center">
          <p class="eyebrow">Deck Services</p>
          <h2 class="section-title mt-3">Built, repaired, and replaced with the right details.</h2>
          <div class="mt-8 divide-y divide-charcoal/10 border-y border-charcoal/10">
            {services.map((service, index) => (
              <a class="group grid gap-3 py-5 transition hover:pl-2 sm:grid-cols-[1fr_auto] sm:items-center" href={`/services/${service.slug}/`}>
                <span>
                  <span class="block font-display text-2xl font-semibold text-charcoal group-hover:text-moss">{service.name}</span>
                  <span class="mt-1 block text-sm leading-6 text-ink/65">{serviceNotes[index]}</span>
                </span>
                <span class="hidden rounded-full border border-charcoal/10 px-4 py-2 text-sm font-extrabold text-charcoal transition group-hover:border-moss group-hover:bg-moss group-hover:text-white sm:inline-flex">View</span>
              </a>
            ))}
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="/services/">View All Services</a>
            <a class="btn btn-outline" href="#estimate">Free Estimate</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container grid gap-12 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="eyebrow">Why Choose DecksRXKC</p>
        <h2 class="section-title mt-3">Clear guidance before construction starts.</h2>
        <p class="lead mt-5">We help you compare layout, materials, stairs, railings, and repair-versus-replacement options.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        {['Local estimates', 'Composite and wood', 'Repair or replacement', 'Railings and stairs'].map((item) => <div class="rounded-2xl border border-charcoal/10 p-5"><h3 class="font-bold text-charcoal">{item}</h3></div>)}
      </div>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container">
      <div class="mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="eyebrow">Project Gallery</p>
          <h2 class="section-title mt-3">Recent project photos.</h2>
        </div>
      </div>
      <GallerySlideshow />
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="grid overflow-hidden rounded-[1.25rem] bg-charcoal shadow-soft lg:grid-cols-[0.95fr_1.05fr]">
        <div class="relative min-h-[360px]">
          <img
            class="absolute inset-0 h-full w-full object-cover opacity-70"
            src="/images/kansas-city-black-railing-deck-stairs-backyard.jpg"
            alt="DecksRXKC deck project serving the Kansas City metro"
            width="1600"
            height="1159"
            loading="lazy"
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-7 text-white sm:p-9">
            <p class="eyebrow eyebrow-on-dark">Service Areas</p>
            <h2 class="mt-3 max-w-lg font-display text-4xl font-semibold leading-tight sm:text-5xl">Deck builder serving the Kansas City metro.</h2>
          </div>
        </div>
        <div class="bg-white p-6 sm:p-8 lg:p-10">
          <div class="grid gap-3 sm:grid-cols-2">
            {areas.slice(0, 6).map((area) => (
              <a class="group rounded-xl border border-charcoal/10 px-4 py-4 transition hover:border-moss hover:bg-cream" href={`/service-areas/${area.slug}/`}>
                <span class="block font-bold text-charcoal group-hover:text-moss">{area.name}</span>
                <span class="mt-1 block text-xs font-bold uppercase tracking-widest text-ink/45">Deck services</span>
              </a>
            ))}
          </div>
          <div class="mt-6 border-t border-charcoal/10 pt-6">
            <p class="text-sm font-extrabold uppercase tracking-widest text-moss">Also serving</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {areas.slice(6).map((area) => (
                <a class="rounded-full bg-cream px-4 py-2 text-sm font-bold text-charcoal transition hover:bg-moss hover:text-white" href={`/service-areas/${area.slug}/`}>{area.name}</a>
              ))}
            </div>
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="/service-areas/">All Service Areas</a>
            <a class="btn btn-outline" href="/contact/">Check My Area</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-[#090908] text-white">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="eyebrow eyebrow-on-dark">Process</p>
          <h2 class="mt-3 max-w-xl font-display text-4xl font-semibold leading-tight sm:text-5xl">From estimate to final walkthrough.</h2>
          <div class="mt-8 overflow-hidden rounded-[1.25rem]">
            <img
              class="aspect-[4/3] w-full object-cover"
              src="/images/kansas-city-covered-deck-framing-addition.jpg"
              alt="Covered deck addition framing during the DecksRXKC build process"
              width="1272"
              height="1236"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div class="relative">
          <div class="overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/[0.04] shadow-2xl shadow-black/20">
            <ol class="divide-y divide-white/10">
              {processSteps.map(([step, note], index) => (
                <li class="grid gap-4 p-5 sm:grid-cols-[2rem_1fr] sm:items-start">
                  <span class="mt-0.5 grid h-8 w-8 place-items-center rounded-full bg-moss text-sm font-black text-white">{index + 1}</span>
                  <span>
                    <span class="block text-xl font-extrabold text-white">{step}</span>
                    <span class="mt-1 block text-sm leading-6 text-white/65">{note}</span>
                  </span>
                </li>
              ))}
            </ol>
          </div>
          <div class="mt-7 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="#estimate">Start Your Estimate</a>
            <a class="btn btn-secondary" href="/gallery/">See Finished Work</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <p class="eyebrow">Homeowner Feedback</p>
      <h2 class="section-title mt-3">What homeowners value.</h2>
      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {['The estimate was clear and helped us understand composite vs wood before choosing.', 'DecksRXKC gave practical advice on our old deck and helped us decide replacement made more sense.', 'The new stairs and railing made the deck feel cleaner, safer, and easier to use.'].map((quote) => <blockquote class="rounded-2xl bg-cream p-6"><p class="leading-7 text-ink/75">“{quote}”</p><cite class="mt-4 block text-sm font-bold not-italic text-charcoal">Kansas City homeowner</cite></blockquote>)}
      </div>
    </div>
  </section>

  <section class="section bg-cream">
    <div class="container grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div><p class="eyebrow">FAQ</p><h2 class="section-title mt-3">Deck questions Kansas City homeowners ask first.</h2></div>
      <FAQ faqs={faqs} />
    </div>
  </section>

  <LeadForm />
  <CTASection />
</BaseLayout>
