---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import LeadForm from '../../components/LeadForm.astro';
import CTASection from '../../components/CTASection.astro';
import { services } from '../../data/services';
import { breadcrumbSchema } from '../../data/schema';
---

<BaseLayout title="Deck Services in Kansas City | DecksRXKC" description="Explore custom deck building, composite decks, wood decks, deck repair, and deck replacement services from DecksRXKC in Kansas City." schemas={[breadcrumbSchema([{ label: 'Home', href: '/' }, { label: 'Services', href: '/services/' }])]}>
  <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Services', href: '/services/' }]} />
  <section class="section bg-cream pt-8">
    <div class="container grid gap-10 lg:grid-cols-[0.75fr_1.25fr] lg:items-start">
      <div>
      <p class="eyebrow">Deck Services</p>
      <h1 class="section-title mt-3">Kansas City deck services built around your home.</h1>
      <p class="lead mt-5 max-w-3xl">Custom decks, composite decks, wood decks, repairs, replacements, railings, and stairs across Kansas City.</p>
      </div>
      <div class="text-link-list">
        {services.map((service) => (
          <a class="group grid gap-3 transition hover:pl-2 sm:grid-cols-[1fr_auto] sm:items-center" href={`/services/${service.slug}/`}>
            <span>
              <span class="block font-display text-2xl font-black text-charcoal group-hover:text-moss">{service.name}</span>
              <span class="mt-2 block leading-7 text-ink/70">{service.description}</span>
            </span>
            <span class="font-extrabold text-timber">View</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  <LeadForm />
  <CTASection />
</BaseLayout>
